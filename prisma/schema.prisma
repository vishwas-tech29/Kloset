generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  price         Float
  comparePrice  Float?
  images        ProductImage[]
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  tags          Tag[]
  variants      Variant[]
  reviews       Review[]
  orderItems    OrderItem[]
  isPublished   Boolean        @default(false)
  isFeatured    Boolean        @default(false)
  metaTitle     String?
  metaDesc      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  publicId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  order     Int     @default(0)
}

model Variant {
  id         String      @id @default(cuid())
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  size       String
  color      String
  stock      Int         @default(0)
  sku        String      @unique
  orderItems OrderItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[]
  order    Int       @default(0)
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Order {
  id              String      @id @default(cuid())
  guestEmail      String
  guestName       String
  status          String      @default("PENDING")
  items           OrderItem[]
  shippingAddress String
  shippingMethod  String
  shippingCost    Float
  subtotal        Float
  discount        Float       @default(0)
  tax             Float
  total           Float
  stripePaymentId String?
  couponCode      String?
  trackingNumber  String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  variant   Variant @relation(fields: [variantId], references: [id])
  variantId String
  quantity  Int
  price     Float
  name      String
  image     String
}

model Review {
  id         String   @id @default(cuid())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  guestName  String
  guestEmail String
  rating     Int
  title      String
  body       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String
  value     Float
  minOrder  Float?
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// AI FEATURES MODELS

// Virtual Try-On Feature
model TryOnResult {
  id          String   @id @default(cuid())
  sessionId   String   // For guest users
  productId   String
  productName String
  userPhoto   String   // Cloudinary URL of user photo
  garmentImage String  // Product image URL
  resultImage String   // Cloudinary URL of try-on result
  category    String
  createdAt   DateTime @default(now())
}

// Custom Design Studio
model CustomDesign {
  id            String        @id @default(cuid())
  sessionId     String        // For guest users
  title         String
  prompt        String?       // AI prompt used
  designData    String        // Fabric.js canvas JSON
  previewImage  String        // Cloudinary URL
  clothingType  String        // tshirt, hoodie, dress, etc.
  baseColor     String
  isPublic      Boolean       @default(false)
  orders        CustomOrder[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CustomOrder {
  id          String       @id @default(cuid())
  design      CustomDesign @relation(fields: [designId], references: [id])
  designId    String
  sessionId   String       // For guest users
  guestEmail  String
  guestName   String
  size        String
  quantity    Int
  color       String
  price       Float
  status      String       @default("PENDING")
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// AI Fashion Expert
model StyleProfile {
  id              String   @id @default(cuid())
  sessionId       String   @unique // For guest users
  bodyType        String?
  preferredStyles String   // JSON array as string
  favoriteColors  String   // JSON array as string
  avoidColors     String   // JSON array as string
  budget          String?  // low, medium, high, luxury
  occasions       String   // JSON array as string
  height          Int?     // in cm
  weight          Int?     // in kg
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChatHistory {
  id        String   @id @default(cuid())
  sessionId String   // For guest users
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
}
